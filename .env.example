# BUGSMASHER — Local environment overrides
# Copy to .env (gitignored). Firebase config lives in firebase-applet-config.json.

# Optional: Google AI Studio / Gemini image generation
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: disable Vite HMR in agent/automation environments
# DISABLE_HMR=true

# Optional: analytics — none | console | posthog | mixpanel
# VITE_ANALYTICS_PROVIDER=console

# Legacy (unused — Supabase removed). Do not set:
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=